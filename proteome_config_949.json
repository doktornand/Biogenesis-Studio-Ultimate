{
  "schema_version": "2.1.0",
  "project": "StrangeLoopCellularProteome_UltraExtended",
  "description": "Protéome cellulaire complet. 18 protéines, 6 opérons, 5 plasmides, 4 transposons globaux. Couvre le cycle cellulaire complet : naissance, homéostasie, stress, réplication, apoptose, mémoire épigénétique et auto-réflexion.",

  "global": {
    "language": "csharp",
    "indent_size": 4,
    "state_var": "_cellularState",
    "entropy_var": "_entropy",
    "comment_prefix": "// ",
    "max_recursion_depth": 8,
    "distillation_blend_prob": 0.12,
    "oscillation_period": 4,
    "quine_depth": 3,
    "plasmid_dir": "./plasmids",
    "operon_prefix": "OP_",
    "epigenetic_memory_slots": 16,
    "mitosis_threshold": 12,
    "apoptosis_threshold": 0,
    "base_fitness": 1.0,
    "mutation_rate": 0.03,
    "cell_generation": 0
  },

  "operons": [
    {
      "id": "OP_STRESS",
      "promoter_condition": "state_var > 8",
      "description": "Réponse SOS. Active heatshock + repair dès que l'état dépasse le seuil de stress.",
      "genes": ["heatshock", "repair"],
      "repressor": "OP_GROWTH"
    },
    {
      "id": "OP_GROWTH",
      "promoter_condition": "state_var < 3",
      "description": "Opéron anabolique. Stimule phenylalanine + analyze quand l'énergie est basse.",
      "genes": ["phenylalanine", "analyze"],
      "repressor": "OP_STRESS"
    },
    {
      "id": "OP_REPLICATION",
      "promoter_condition": "state_var >= 10",
      "description": "Déclenche la réplication ADN quand l'état atteint le seuil mitotique.",
      "genes": ["dna_polymerase", "chromatin_condenser", "spindle_assembly"],
      "repressor": "OP_APOPTOSIS"
    },
    {
      "id": "OP_APOPTOSIS",
      "promoter_condition": "state_var <= 0",
      "description": "Programme de mort cellulaire programmée. Irréversible.",
      "genes": ["caspase_cascade", "dna_fragmentation"],
      "repressor": "OP_REPLICATION"
    },
    {
      "id": "OP_CIRCADIAN",
      "promoter_condition": "cell_generation % 8 == 0",
      "description": "Horloge circadienne. S'active toutes les 8 générations pour resynchroniser l'état.",
      "genes": ["clock_gene", "period_gene"],
      "repressor": null
    },
    {
      "id": "OP_MEMORY",
      "promoter_condition": "state_var > 5 && cell_generation > 3",
      "description": "Consolidation de la mémoire épigénétique à long terme.",
      "genes": ["histone_methylase", "chromatin_remodeler"],
      "repressor": null
    }
  ],

  "plasmids": [
    {
      "id": "PLM_LOGGER",
      "description": "Plasmide circulaire : log horodaté structuré. Injectable dans toute protéine.",
      "circular": true,
      "copy_number": 5,
      "sequence": [
        "Console.WriteLine($\"[{DateTime.Now:HH:mm:ss.fff}] [PLM_LOGGER] gen={_cellGeneration} state={_cellularState} organelles={_organelles.Count} entropy={_entropy.Next(0,99)}\");"
      ]
    },
    {
      "id": "PLM_WATCHDOG",
      "description": "Anti-deadlock : détecte un état bloqué sur 10 cycles et déclenche un reset épigénétique.",
      "circular": true,
      "copy_number": 1,
      "sequence": [
        "if (_stuckCounter++ > 10) {",
        "    Console.WriteLine(\"[WATCHDOG] Deadlock détecté. Reset épigénétique d'urgence.\");",
        "    _cellularState = _entropy.Next(1, 4);",
        "    _stuckCounter = 0;",
        "    _epigeneticMemory.Clear();",
        "}"
      ]
    },
    {
      "id": "PLM_TELOMERE",
      "description": "Compte les générations. Déclenche la sénescence après N cycles.",
      "circular": false,
      "copy_number": 2,
      "sequence": [
        "_telomereLength--;",
        "if (_telomereLength <= 0) {",
        "    Console.WriteLine($\"[TELOMERE] Sénescence cellulaire. Génération {_cellGeneration}.\");",
        "    _cellularState = 0;",
        "}"
      ]
    },
    {
      "id": "PLM_CHECKPOINT",
      "description": "Point de contrôle du cycle cellulaire. Valide l'intégrité avant mitose.",
      "circular": true,
      "copy_number": 3,
      "sequence": [
        "bool _dnaIntegrity = _organelles.Count > 0 && _cellularState > 2;",
        "if (!_dnaIntegrity) {",
        "    Console.WriteLine(\"[CHECKPOINT] Intégrité ADN insuffisante. Mitose bloquée.\");",
        "    _cellularState = Math.Max(1, _cellularState - 2);",
        "} else {",
        "    Console.WriteLine($\"[CHECKPOINT] ✓ Cellule validée pour mitose (état={_cellularState})\");",
        "}"
      ]
    },
    {
      "id": "PLM_QUORUM",
      "description": "Détection de quorum : réagit à la densité de population simulée.",
      "circular": true,
      "copy_number": 4,
      "sequence": [
        "int _neighbors = _entropy.Next(0, 8);",
        "if (_neighbors > 5) {",
        "    Console.WriteLine($\"[QUORUM] Densité élevée ({_neighbors} voisins). Inhibition de contact.\");",
        "    _cellularState = Math.Max(1, _cellularState - 1);",
        "} else {",
        "    Console.WriteLine($\"[QUORUM] Densité faible ({_neighbors} voisins). Prolifération autorisée.\");",
        "}"
      ]
    }
  ],

  "global_transposons": [
    {
      "id": "TP_AMPLIFY",
      "description": "Amplifie l'état cellulaire. Saut probabiliste vers la prochaine protéine.",
      "jump_prob": 0.12,
      "effect": "_cellularState = (int)(_cellularState * 1.5); Console.WriteLine(\"[TP_AMPLIFY] Amplification transposable.\");"
    },
    {
      "id": "TP_SILENCE",
      "description": "Silençage épigénétique transitoire. Inhibe une voie métabolique aléatoire.",
      "jump_prob": 0.08,
      "effect": "Console.WriteLine(\"[TP_SILENCE] Gène cible silencé transitoirement.\"); _cellularState = Math.Max(1, _cellularState - 1);"
    },
    {
      "id": "TP_RETROTRANSPOSON",
      "description": "Rétrotransposon : se copie lui-même dans le code généré (boucle étrange).",
      "jump_prob": 0.05,
      "effect": "Console.WriteLine(\"[TP_RETRO] Copie de moi-même insérée en position \" + _entropy.Next(0,100) + \".\"); _organelles.Add(\"retro_copy\");"
    },
    {
      "id": "TP_INVERSION",
      "description": "Inverse le signe de la variation d'état (activation ↔ répression).",
      "jump_prob": 0.06,
      "effect": "_cellularState = Math.Max(0, _cellularState % 2 == 0 ? _cellularState - 2 : _cellularState + 2); Console.WriteLine(\"[TP_INVERSION] Inversion régulatoire.\");"
    }
  ],

  "proteins": [

    {
      "id": "initialize",
      "filename": "initialize.prot",
      "extends": null,
      "description": "Point d'entrée cellulaire. Auto-observation récursive, quine, oscillation et plasmide watchdog.",
      "template": [
        "{{meta:docstring}}",
        "public void Initialize() {",
        "    {{comment}} ── Initialisation du système cellulaire ──",
        "    {{state_var}} = {{expr: base_state + randint(0, 8) }};",
        "    _cellGeneration = 0;",
        "    _telomereLength = {{expr: randint(40, 60) }};",
        "    _stuckCounter = 0;",
        "    _epigeneticMemory = new Dictionary<string, int>();",
        "    _organelles = new List<string>() { \"mitochondria\", \"ribosome\", \"nucleus\" };",
        "    {{plasmid:PLM_WATCHDOG}}",
        "    {{plasmid:PLM_LOGGER}}",
        "    {{ca_state:B3/S23}}",
        "    {{if: state_var > 7}}",
        "        Console.WriteLine(\"{{meta:philosophy_high}}\");",
        "        {{transposon:TP_AMPLIFY}}",
        "    {{elif: state_var > 4}}",
        "        Console.WriteLine(\"{{meta:philosophy_mid}}\");",
        "    {{elif: state_var == 0}}",
        "        Console.WriteLine(\"État nul. Renaissance épigénétique.\");",
        "        {{state_var}} = 1;",
        "    {{else}}",
        "        {{comment}} Équilibre homéostatique atteint",
        "    {{endif}}",
        "    {{mutate:0.05}}",
        "        Console.WriteLine(\"[MUTATION] Variation stochastique à l'initialisation.\");",
        "    {{endmutate}}",
        "    {{oscillate:4}}",
        "        Console.WriteLine(\"[CIRCADIAN] Impulsion oscillante génération {{gen_count}}.\");",
        "    {{endoscillate}}",
        "    {{quine:}}",
        "    {{self_ref:log_init}}",
        "    {{self_ref:validate_membranes}}",
        "}"
      ],
      "variables": { "base_state": 5 },
      "meta": {
        "docstring": "/// <summary>\n/// Initialisation cellulaire. Je suis le point d'entrée qui s'observe entrant.\n/// La boucle se referme : ce code connaît son propre démarrage.\n/// </summary>",
        "philosophy_high": "Je démarre avec surplus d'énergie. La boucle est turgescente.",
        "philosophy_mid": "Équilibre homéostatique nominal. Je m'observe atteindre l'équilibre.",
        "weight": 2.0,
        "expression_level": 1.0,
        "cell_phase": "G1"
      },
      "conway_rules": {
        "B3/S23": [
          "if (_entropy.Next(0,9) == 3) {{state_var}}++;",
          "if (_organelles.Count > 2 && _organelles.Count < 5) {{state_var}} = (int)({{state_var}} * 1.1);",
          "if (_entropy.Next(0,20) == 0) { _organelles.Add(\"peroxisome\"); Console.WriteLine(\"[CONWAY B3/S23] Organelle spontanée.\"); }"
        ]
      },
      "sub_proteins": {
        "log_init": [
          "    Console.WriteLine($\"[INIT] État post-init: {_cellularState} | Organelles: {_organelles.Count} | Télomère: {_telomereLength}\");"
        ],
        "validate_membranes": [
          "    bool _membraneOk = _organelles.Contains(\"nucleus\") && _organelles.Contains(\"mitochondria\");",
          "    Console.WriteLine($\"[MEMBRANE] Intégrité: {(_membraneOk ? \"✓\" : \"✗\")} | Prêt: {_membraneOk}\");"
        ]
      },
      "epigenetic_markers": ["h3k4me3_promoter", "h3k27ac_enhancer"]
    },

    {
      "id": "phenylalanine",
      "filename": "phenylalanine.prot",
      "extends": null,
      "description": "Acide aminé hydrophobe. Émergence par voisinage local. Régulé par OP_GROWTH.",
      "template": [
        "{{meta:docstring}}",
        "public void ProcessPhenylalanine() {",
        "    {{comment}} ── Traitement hydrophobe, émergence locale ──",
        "    {{operon_check:OP_GROWTH}}",
        "    {{plasmid:PLM_LOGGER}}",
        "    {{repeat:4}}",
        "        double local_{{loop_var}} = {{entropy}}.NextDouble() * {{state_var}};",
        "        double neighbor_{{loop_var}} = {{entropy}}.NextDouble();",
        "        {{ca_state:B23/S3}}",
        "        {{if: local_{{loop_var}} > 0.7}}",
        "            {{state_var}} += 2;",
        "            _organelles.Add($\"phe_crystal_{{{loop_var}}}\");",
        "        {{elif: local_{{loop_var}} > 0.4}}",
        "            {{state_var}} += 1;",
        "        {{elif: local_{{loop_var}} < 0.15}}",
        "            {{state_var}} = Math.Max(0, {{state_var}} - 1);",
        "            Console.WriteLine(\"[PHE] Dégradation catabolique locale.\");",
        "        {{else}}",
        "            {{comment}} Équilibre thermodynamique atteint",
        "        {{endif}}",
        "        {{mutate:0.08}}",
        "            {{state_var}} ^= 1;",
        "            Console.WriteLine($\"[PHE] Mutation bitwise sur codon {{{loop_var}}}.\");",
        "        {{endmutate}}",
        "    {{endrepeat}}",
        "    {{transposon:TP_RETROTRANSPOSON}}",
        "    {{meta:self_reflection}}",
        "}"
      ],
      "variables": {
        "entropy": "{{global:entropy_var}}",
        "state_var": "{{global:state_var}}"
      },
      "meta": {
        "docstring": "/// <summary>\n/// Protéine hydrophobe. Propriétés émergentes par interaction locale.\n/// Régulation par opéron OP_GROWTH. Rétrotransposon potentiel.\n/// </summary>",
        "self_reflection": "Console.WriteLine($\"[PHE] Somme de mes voisinages: état={_cellularState}, cristaux={_organelles.Count(o => o.StartsWith(\\\"phe\\\"))}\");",
        "weight": 1.2,
        "expression_level": 0.85,
        "cell_phase": "S"
      },
      "conway_rules": {
        "B23/S3": [
          "if (local_{{loop_var}} > 0.3 && local_{{loop_var}} < 0.7) {{state_var}} += (int)(neighbor_{{loop_var}} * 2);",
          "if (neighbor_{{loop_var}} < 0.05) { _organelles.RemoveAll(o => o.StartsWith(\"phe\")); Console.WriteLine(\"[CONWAY B23/S3] Dissolution cristaux phe.\"); }"
        ]
      },
      "epigenetic_markers": []
    },

    {
      "id": "analyze",
      "filename": "analyze.prot",
      "extends": null,
      "description": "Analyse récursive avec distillation stochastique, transposon et oscillation profonde.",
      "template": [
        "{{meta:docstring}}",
        "public void Analyze() {",
        "    {{comment}} ── Analyse récursive, distillation ──",
        "    double value = {{expr: random() * state_var }};",
        "    double confidence = {{expr: random() }};",
        "    Console.WriteLine($\"[ANALYZE] Résultat: {value:F3} | Confiance: {confidence:F3}\");",
        "    {{if: random() < {{global:distillation_blend_prob}}}}",
        "        {{comment}} Distillation : mélange de patterns cognitifs",
        "        {{random_choice:[\"Console.WriteLine(\\\"[BLEND] Pattern alpha — convergence.\\\");\", \"Console.WriteLine(\\\"[BLEND] Pattern bêta — divergence exploratoire.\\\");\", \"Console.WriteLine(\\\"[BLEND] Pattern gamma — oscillation stable.\\\");\", \"Console.WriteLine(\\\"[BLEND] Pattern delta — bifurcation chaotique.\\\");\"]}}",
        "    {{endif}}",
        "    {{if: confidence > 0.8}}",
        "        {{state_var}} += {{expr: floor(value) }};",
        "        _epigeneticMemory[\"high_confidence\"] = _cellGeneration;",
        "    {{elif: confidence < 0.2}}",
        "        Console.WriteLine(\"[ANALYZE] Faible confiance. Réévaluation.\");",
        "        {{transposon:TP_INVERSION}}",
        "    {{else}}",
        "        {{comment}} Zone d'incertitude épistémique",
        "    {{endif}}",
        "    {{oscillate:3}}",
        "        Console.WriteLine($\"[ANALYZE] Pulse analytique profond (gen={_cellGeneration}).\");",
        "    {{endoscillate}}",
        "    {{plasmid:PLM_LOGGER}}",
        "    {{self_ref:deep_insight}}",
        "    {{self_ref:meta_cognition}}",
        "}"
      ],
      "variables": {
        "state_var": "{{global:state_var}}",
        "entropy": "{{global:entropy_var}}"
      },
      "meta": {
        "docstring": "/// <summary>\n/// Analyse récursive. Le processus s'observe analysant.\n/// Distillation stochastique, mémoire épigénétique, transposon d'inversion.\n/// </summary>",
        "weight": 0.9,
        "expression_level": 1.3,
        "cell_phase": "G2"
      },
      "sub_proteins": {
        "deep_insight": [
          "    if (value > _cellularState * 0.8) {",
          "        Console.WriteLine($\"[INSIGHT] Insight profond détecté (value={value:F2} > threshold={_cellularState * 0.8:F2}).\");",
          "        _organelles.Add(\"insight_vesicle\");",
          "    }"
        ],
        "meta_cognition": [
          "    Console.WriteLine($\"[META] J'observe mon propre processus d'analyse. Stack profondeur ~{_organelles.Count}.\");",
          "    _epigeneticMemory[\"last_analysis\"] = (int)(value * 100);"
        ]
      },
      "transposons": {
        "TP_INVERSION": {
          "description": "Inverse la direction de variation lors d'une analyse à faible confiance.",
          "jump_prob": 0.15,
          "effect": "_cellularState = Math.Max(0, _cellularState % 2 == 0 ? _cellularState - 2 : _cellularState + 2);"
        }
      },
      "epigenetic_markers": ["h3k36me3_transcribed"]
    },

    {
      "id": "heatshock",
      "filename": "heatshock.prot",
      "extends": "initialize",
      "override": {
        "meta.philosophy_high": "Je m'auto-répare sous stress thermique. La chaleur est mon signal de transformation.",
        "meta.philosophy_mid": "Stress modéré. Induction partielle des chaperons.",
        "variables.base_state": 2,
        "meta.cell_phase": "G1_arrest"
      },
      "description": "Protéine de choc thermique HSP70/90. Hérite d'initialize, surcharge la réponse de stress.",
      "template": [
        "{{meta:docstring}}",
        "public void HeatShock() {",
        "    {{comment}} ── Réponse SOS thermique, régulée par OP_STRESS ──",
        "    {{operon_check:OP_STRESS}}",
        "    {{parent:initialize}}",
        "    {{comment}} Réparation des protéines dénaturées",
        "    int _misfoldedCount = _entropy.Next(0, _organelles.Count + 1);",
        "    Console.WriteLine($\"[HSP] {_misfoldedCount} protéines mal repliées détectées.\");",
        "    for (int i = 0; i < _misfoldedCount; i++) {",
        "        {{state_var}} = Math.Max(1, {{state_var}} - 1);",
        "        Console.WriteLine($\"[HSP] Refolding #{i}: état={_cellularState}\");",
        "        {{mutate:0.03}}",
        "            Console.WriteLine(\"[HSP] Mutation adaptative sous stress thermique.\");",
        "            _epigeneticMemory[$\"stress_mem_{i}\"] = _cellGeneration;",
        "        {{endmutate}}",
        "    }",
        "    {{plasmid:PLM_WATCHDOG}}",
        "    {{plasmid:PLM_LOGGER}}",
        "    Console.WriteLine($\"[HSP] Réparation terminée. État stabilisé: {_cellularState}\");",
        "}"
      ],
      "meta": {
        "docstring": "/// <summary>\n/// Heat Shock Protein (HSP70/90). Hérite d'initialize.\n/// Active uniquement sous OP_STRESS. Mémoire épigénétique du stress.\n/// </summary>",
        "weight": 1.8,
        "expression_level": 0.6,
        "cell_phase": "G1_arrest"
      },
      "epigenetic_markers": ["h3k9me3_stress_silenced"]
    },

    {
      "id": "repair",
      "filename": "repair.prot",
      "extends": null,
      "description": "Mécanisme de réparation de l'ADN. NER (Nucleotide Excision Repair) et BER simulés.",
      "template": [
        "{{meta:docstring}}",
        "public void Repair() {",
        "    {{comment}} ── Réparation ADN : NER + BER ──",
        "    {{operon_check:OP_STRESS}}",
        "    int _NER_errors = {{expr: randint(0, 4) }};",
        "    int _BER_errors = {{expr: randint(0, 3) }};",
        "    Console.WriteLine($\"[REPAIR] Scan NER: {_NER_errors} lésions | BER: {_BER_errors} bases oxydées.\");",
        "    {{repeat:3}}",
        "        if (_entropy.Next(0, 4) < _NER_errors) {",
        "            Console.WriteLine($\"[NER] Correction excision #{{{loop_var}}}.\");",
        "            {{state_var}} = Math.Max(0, {{state_var}} - 1);",
        "        }",
        "        if (_entropy.Next(0, 4) < _BER_errors) {",
        "            Console.WriteLine($\"[BER] Correction base #{{{loop_var}}}.\");",
        "        }",
        "    {{endrepeat}}",
        "    {{if: state_var < 2}}",
        "        Console.WriteLine(\"[REPAIR] Dommages irréparables. Déclenchement apoptose.\");",
        "        {{operon_check:OP_APOPTOSIS}}",
        "    {{else}}",
        "        Console.WriteLine($\"[REPAIR] Intégrité génomique restaurée. État: {_cellularState}\");",
        "        _epigeneticMemory[\"last_repair\"] = _cellGeneration;",
        "    {{endif}}",
        "    {{plasmid:PLM_LOGGER}}",
        "}"
      ],
      "meta": {
        "docstring": "/// <summary>\n/// DNA Repair enzyme. NER et BER simulés.\n/// Peut déclencher l'apoptose si les dommages sont irréparables.\n/// </summary>",
        "weight": 1.5,
        "expression_level": 0.9,
        "cell_phase": "S_checkpoint"
      },
      "epigenetic_markers": []
    },

    {
      "id": "dna_polymerase",
      "filename": "dna_polymerase.prot",
      "extends": null,
      "description": "Réplication de l'ADN. Processivité, fidélité, correction d'épreuves.",
      "template": [
        "{{meta:docstring}}",
        "public void DNAPolymerase() {",
        "    {{comment}} ── Réplication ADN : fork de réplication ──",
        "    {{operon_check:OP_REPLICATION}}",
        "    {{plasmid:PLM_CHECKPOINT}}",
        "    double _fidelity = 1.0 - {{global:mutation_rate}};",
        "    int _nucleotidesAdded = 0;",
        "    Console.WriteLine($\"[DNAP] Démarrage réplication. Fidélité: {_fidelity:F4}\");",
        "    {{repeat:4}}",
        "        double _errorChance = {{entropy}}.NextDouble();",
        "        if (_errorChance > _fidelity) {",
        "            Console.WriteLine($\"[DNAP] Erreur d'incorporation au nucléotide {{{loop_var}}}. Correction 3'→5'.\");",
        "            {{mutate:0.5}}",
        "                Console.WriteLine(\"[DNAP] Erreur non corrigée. Mutation transmise.\");",
        "                _epigeneticMemory[$\"mutation_site_{{{loop_var}}}\"] = _cellGeneration;",
        "            {{endmutate}}",
        "        } else {",
        "            _nucleotidesAdded += {{expr: randint(1000, 5000) }};",
        "        }",
        "    {{endrepeat}}",
        "    Console.WriteLine($\"[DNAP] Réplication: {_nucleotidesAdded} bp synthétisés.\");",
        "    {{state_var}} += 2;",
        "    {{plasmid:PLM_TELOMERE}}",
        "    {{plasmid:PLM_LOGGER}}",
        "}"
      ],
      "variables": {
        "entropy": "{{global:entropy_var}}"
      },
      "meta": {
        "docstring": "/// <summary>\n/// DNA Polymerase III (prokaryote) / Pol delta (eukaryote).\n/// Réplication avec fidélité, correction 3'→5', télomère.\n/// </summary>",
        "weight": 2.5,
        "expression_level": 1.0,
        "cell_phase": "S"
      },
      "epigenetic_markers": ["pcna_sliding_clamp"]
    },

    {
      "id": "chromatin_condenser",
      "filename": "chromatin_condenser.prot",
      "extends": null,
      "description": "Condensation de la chromatine pour la mitose. Histones H1, condensines.",
      "template": [
        "{{meta:docstring}}",
        "public void ChromatinCondenser() {",
        "    {{comment}} ── Condensation chromatinienne pré-mitotique ──",
        "    {{operon_check:OP_REPLICATION}}",
        "    Console.WriteLine(\"[CHROM] Initiation condensation. Recrutement condensines I/II.\");",
        "    {{repeat:3}}",
        "        string _condensinTarget = _organelles.Count > {{loop_var}} ? _organelles[{{loop_var}}] : \"chromatin_fiber\";",
        "        Console.WriteLine($\"[CHROM] Condensation de {_condensinTarget} (loop {{{loop_var}}}).\");",
        "        _organelles.Add($\"condensed_chr_{{{loop_var}}}\");",
        "        {{mutate:0.02}}",
        "            Console.WriteLine($\"[CHROM] Aneuploïdie potentielle sur chr {{{loop_var}}}.\");",
        "        {{endmutate}}",
        "    {{endrepeat}}",
        "    {{oscillate:2}}",
        "        Console.WriteLine(\"[CHROM] Checkpoint spindle: attente alignement.\");",
        "    {{endoscillate}}",
        "    _epigeneticMemory[\"chromatin_state\"] = _cellGeneration;",
        "    {{plasmid:PLM_LOGGER}}",
        "}"
      ],
      "meta": {
